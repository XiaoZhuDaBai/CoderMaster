# =====================================================
# CodeMaster OJ 环境变量配置
# =====================================================
#
# 场景 A - 单服务器部署：使用 docker-compose.yml
# 场景 B - 双服务器部署：
#   - 服务器 A（基础设施）：使用 docker-compose.infra.yml
#   - 服务器 B（应用服务）：使用 docker-compose.app.yml
#
# =====================================================

# ==================== 服务器 A：基础设施 ====================
# 部署在基础设施服务器，填写该服务器的内网/公网 IP

# 服务器 A 的 IP 地址（应用服务器访问基础设施时使用）
INFRA_SERVER_HOST=192.168.1.100

# ==================== Nacos 配置中心 ====================
NACOS_SERVER_ADDR=${INFRA_SERVER_HOST}:8848

# ==================== MySQL 数据库 ====================
DB_HOST=${INFRA_SERVER_HOST}
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password

# ==================== Redis 缓存 ====================
REDIS_HOST=${INFRA_SERVER_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== RabbitMQ 消息队列 ====================
RABBITMQ_HOST=${INFRA_SERVER_HOST}
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# ==================== JWT 配置 ====================
# 生产环境请务必修改为强密钥（至少32位随机字符串）
JWT_SECRET=change-this-to-a-secure-random-key-in-production

# ==================== 邮件服务 ====================
# QQ邮箱示例配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-auth-code

# ==================== AI 服务 (DeepSeek) ====================
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your-deepseek-api-key

# ==================== AI 交叉验证 (通义千问) ====================
# 用于对生成内容做二次验证，推荐使用不同模型系列
CROSS_VALIDATION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CROSS_VALIDATION_API_KEY=your-qwen-api-key
CROSS_VALIDATION_MODEL_NAME=qwen-plus

# ==================== 监控配置 ====================
GRAFANA_PASSWORD=admin
